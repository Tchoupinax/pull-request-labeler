{
  "[javascript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint",
    "editor.formatOnSave": true
  },
  "[typescript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint",
    "editor.formatOnSave": true
  },
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always",
    "source.organizeImports": "never"
  },
  "eslint.format.enable": true,
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#e1d3ff",
    "activityBar.background": "#e1d3ff",
    "activityBar.foreground": "#15202b",
    "activityBar.inactiveForeground": "#15202b99",
    "activityBarBadge.background": "#ff6720",
    "activityBarBadge.foreground": "#15202b",
    "commandCenter.border": "#15202b99",
    "sash.hoverBorder": "#e1d3ff",
    "statusBar.background": "#bfa0ff",
    "statusBar.foreground": "#15202b",
    "statusBarItem.hoverBackground": "#9d6dff",
    "statusBarItem.remoteBackground": "#bfa0ff",
    "statusBarItem.remoteForeground": "#15202b",
    "titleBar.activeBackground": "#bfa0ff",
    "titleBar.activeForeground": "#15202b",
    "titleBar.inactiveBackground": "#bfa0ff99",
    "titleBar.inactiveForeground": "#15202b99"
  },
  "peacock.color": "#bfa0ff"
}
